# Backend API
PORT=3001
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-moi-en-production

# MySQL (MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=miniprojet_ecommerce
DB_POOL_SIZE=10
DB_SSL=false

# Optionnel (recommandé en production): URL unique de connexion MySQL
# Exemple: mysql://user:password@host:3306/database
DATABASE_URL=

# Alias Railway recommandé (service link)
# MYSQL_URL=${{MySQL.MYSQL_URL}}
MYSQL_URL=

# Runtime
NODE_ENV=development

# Alias Railway possibles (le backend accepte aussi ces noms):
# URL_PUBLIC_MYSQL=mysql://user:password@ballast.proxy.rlwy.net:xxxxx/railway
# URL_MYSQL=mysql://user:password@mysql.railway.internal:3306/railway
# MYSQL_URL=
# MYSQL_PRIVATE_URL=
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# Frontend (Vite) - optionnel si tu utilises le proxy Vite
# En production Railway avec front+back sur le même domaine, laisse vide.
VITE_API_URL=

# Supabase (Frontend)
VITE_SUPABASE_URL=votre_url_supabase
VITE_SUPABASE_ANON_KEY=votre_cle_supabase_anon

# Support (WhatsApp)
VITE_SUPPORT_WHATSAPP_NUMBER=2435421445

# Paiements Airtel Money
AIRTEL_MONEY_MODE=mock
AIRTEL_MONEY_MERCHANT_MSISDN=0977342386
AIRTEL_MONEY_BASE_URL=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=

# Configuration Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application