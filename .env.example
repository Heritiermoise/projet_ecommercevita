# Backend API
PORT=3001
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-moi-en-production

# MySQL (MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=miniprojet_ecommerce
DB_POOL_SIZE=10
DB_SSL=false

# Optionnel (recommandé en production): URL unique de connexion MySQL
# Exemple: mysql://user:password@host:3306/database
DATABASE_URL=

# Frontend (Vite) - optionnel si tu utilises le proxy Vite
VITE_API_URL=http://localhost:3001

# Support (WhatsApp) - met le numéro en format international sans + (ex: 243977342386)
VITE_SUPPORT_WHATSAPP_NUMBER=

# Paiements Airtel Money
# mode=mock (par défaut) ou provider (si tu as des identifiants officiels)
AIRTEL_MONEY_MODE=mock
AIRTEL_MONEY_MERCHANT_MSISDN=0977342386
AIRTEL_MONEY_BASE_URL=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=

# Configuration Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
